---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import SeriesBlogPost from "../../layouts/SeriesBlogPost.astro";
import { getSeriesBySlug } from "../../data/series";
import { getSeriesPosts } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await render(post);
const seriesPosts = post.data.series
  ? getSeriesPosts({
      posts: await getCollection("blog"),
      slug: post.data.series,
    })
  : [];
const currentSeries = getSeriesBySlug({ slug: post.data.series });
const shouldUseSeriesPost = Boolean(currentSeries && seriesPosts.length > 0);
---

{
  shouldUseSeriesPost ? (
    <SeriesBlogPost
      {...post.data}
      currentPostId={post.id}
      headings={headings}
      seriesPosts={seriesPosts}
    >
      <Content />
    </SeriesBlogPost>
  ) : (
    <BlogPost {...post.data} id={post.id}>
      <Content />
    </BlogPost>
  )
}
