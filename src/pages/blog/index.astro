---
import { getCollection } from "astro:content";
import BasePage from "../../layouts/BasePage.astro";
import PostListItem from "../../components/PostListItem.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getSeriesSummaries, sortPosts } from "../../utils/blog";

const posts = sortPosts({
  posts: await getCollection("blog"),
});
const seriesList = getSeriesSummaries({ posts });
---

<BasePage title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main>
    <section class="series-overview">
      <div class="section-heading">
        <h2>系列专题</h2>
        <p>如果你想连续阅读一个主题，可以先从系列进入。</p>
      </div>
      <ul class="series-list">
        {
          seriesList.map((series) => (
            <li>
              <a class="series-link" href={`/series/${series.slug}/`}>
                <p class="series-meta">
                  {series.theme} · {series.postCount} 篇文章 · {series.status}
                </p>
                <h3>{series.title}</h3>
                <p class="series-description">{series.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
    <section>
      <ul class="post-list">
        {posts.map((post) => <PostListItem post={post} titleAs="h4" />)}
      </ul>
    </section>
  </main>
</BasePage>

<style>
  main {
    width: min(calc(100% - 2rem), 860px);
  }

  .series-overview {
    margin-bottom: 3rem;
    margin-top: 1rem;
  }
  .section-heading {
    margin-bottom: 1.1rem;
  }
  .section-heading h2 {
    margin: 0 0 0.35rem;
  }
  .section-heading p {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.98rem;
  }
  .series-list,
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .series-list li,
  .post-list li {
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  .series-link,
  .post-link {
    display: block;
    padding: 1.35rem 0;
    text-decoration: none;
  }
  .series-link:hover h3,
  .post-link:hover .title {
    color: var(--accent);
  }
  .series-link h3 {
    margin: 0 0 0.35rem;
    font-size: 1.3rem;
    line-height: 1.35;
  }
  .series-meta,
  .series-description {
    margin: 0;
    color: rgb(var(--gray-dark));
    line-height: 1.85;
  }
  @media (max-width: 760px) {
    main {
      width: min(calc(100% - 1.25rem), 860px);
    }
    .series-link h3 {
      font-size: 1.18rem;
    }
  }
</style>
