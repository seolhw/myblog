---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import PostMeta from "../components/PostMeta.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { sortPosts } from "../utils/blog";

const posts = sortPosts({
  posts: await getCollection("blog"),
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`时间线 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      main.timeline {
        width: min(calc(100% - 2rem), 860px);
      }
      .page-heading {
        margin-bottom: 3rem;
      }
      .page-heading p {
        max-width: 42rem;
        color: rgb(var(--gray));
        line-height: 1.9;
      }
      .timeline ul {
        list-style: none;
        padding: 0;
        margin: 0;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .timeline li {
        border-bottom: 1px solid rgb(var(--gray-light));
      }
      .timeline .post-link {
        display: block;
        padding: 1.25rem 0;
        text-decoration: none;
      }
      .timeline h3 {
        margin-bottom: 0.35rem;
        line-height: 1.35;
      }
      .timeline .post-link:hover h3 {
        color: var(--accent);
      }
      .post-meta-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .post-meta-row > :last-child {
        flex-shrink: 0;
      }
      .post-meta-row .date {
        margin: 0;
        color: rgb(var(--gray));
        font-size: 0.92rem;
      }
      .description {
        margin: 0 0 0.8rem;
        color: rgb(var(--gray-dark));
        line-height: 1.85;
      }
      @media (max-width: 760px) {
        main.timeline {
          width: min(calc(100% - 1.25rem), 860px);
        }
        .post-meta-row {
          align-items: flex-start;
          flex-direction: column;
          gap: 0.55rem;
        }
        .timeline h3 {
          font-size: 1.18rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main class="timeline">
      <header class="page-heading">
        <h2>时间线</h2>
        <p>
          按发布时间倒序浏览所有文章。相比文章页，这里更适合快速扫读最近一段时间写了什么。
        </p>
      </header>
      <ul>
        {
          posts.map((post) => (
            <li>
              <a class="post-link" href={`/blog/${post.id}/`}>
                <h3>{post.data.title}</h3>
                <p class="description">{post.data.description}</p>
                <div class="post-meta-row">
                  <p class="date">
                    时间：
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                  <PostMeta
                    series={post.data.series}
                    seriesOrder={post.data.seriesOrder}
                    topics={post.data.topics}
                  />
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
