---
import { getCollection } from "astro:content";
import BasePage from "../layouts/BasePage.astro";
import PostListItem from "../components/PostListItem.astro";
import { GITHUB_URL, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { getSeriesSummaries, sortPosts } from "../utils/blog";

const allPosts = sortPosts({
  posts: await getCollection("blog"),
});
const posts = allPosts.slice(0, 5);
const seriesList = getSeriesSummaries({ posts: allPosts });
const agentSeries = seriesList.find(
  (series) => series.slug === "ai-agent-engineering-20",
);
const otherSeries = seriesList.filter(
  (series) => series.slug !== agentSeries?.slug,
);

const caseStudies = [
  {
    label: "Case A",
    title: "案例 A：生产级 RAG / Knowledge Agent",
    problem: "目标问题待补充：说明知识库问答、企业知识检索或垂直领域辅助决策的真实业务场景。",
    agentCapability:
      "Agent 能力待补充：RAG、tool calling、memory、引用溯源、人机确认流程。",
    engineeringEvidence:
      "工程证据待补充：eval 数据集、召回质量、latency、cost、observability、安全边界。",
    status: "案例详情待补充",
  },
  {
    label: "Case B",
    title: "案例 B：业务流程自动化 Agent",
    problem: "目标问题待补充：说明跨系统流程、审批、同步、运营或交付自动化场景。",
    agentCapability:
      "Agent 能力待补充：workflow、tool calling、状态管理、human-in-the-loop、失败恢复。",
    engineeringEvidence:
      "工程证据待补充：流程成功率可替换为真实指标、trace、告警、回滚与审计设计。",
    status: "案例详情待补充",
  },
  {
    label: "Case C",
    title: "案例 C：开发者工具 / Coding Agent 实践",
    problem: "目标问题待补充：说明代码理解、工程任务拆解、开发者效率或 IDE 辅助场景。",
    agentCapability:
      "Agent 能力待补充：代码上下文、工具调用、任务规划、沙箱执行、结果校验。",
    engineeringEvidence:
      "工程证据待补充：eval、测试覆盖、执行日志、权限隔离、成本和响应时间。",
    status: "案例详情待补充",
  },
];

const capabilities = [
  {
    label: "Agent 工程化",
    text: "关注工具调用、上下文工程、工作流编排、记忆、评估与可观测性，把 Agent 从 demo 推向可维护系统。",
  },
  {
    label: "Eval & Observability",
    text: "关注离线评估、线上 trace、失败样本分析、成本与延迟，让 Agent 的质量变化可以被持续观察。",
  },
  {
    label: "安全边界",
    text: "关注 prompt injection、工具权限、审计日志、人工确认和敏感操作隔离，避免 Agent 越权执行。",
  },
  {
    label: "产品化意识",
    text: "习惯从用户场景、成本、稳定性和迭代节奏看 AI 应用，而不是只停在模型调用和提示词。",
  },
];
---

<BasePage title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <main>
    <section class="hero">
      <p class="eyebrow">AI Agent Engineer / TypeScript / Node.js / React</p>
      <h1>把 AI Agent 做成可靠、可评估、可交付的产品系统。</h1>
      <p class="hero-summary">
        你好，我是 huiwang，一名正在求职 <strong>AI Agent 工程师</strong>&nbsp;
        岗位的全栈工程师。我关心的不只是调通模型，而是 Agent
        的工具链、上下文、状态、评估、可观测性和产品化落地。
      </p>
      <div class="hero-actions" aria-label="主要链接">
        <a class="primary-action" href="/series/ai-agent-engineering-20/"
          >阅读 Agent 工程化系列</a
        >
        <a href="/about">查看履历</a>
        <a href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
      </div>
      <dl class="signal-strip" aria-label="候选人概要">
        <div>
          <dt>8 年</dt>
          <dd>全栈研发经验</dd>
        </div>
        <div>
          <dt>20 讲</dt>
          <dd>AI Agent 工程化写作</dd>
        </div>
        <div>
          <dt>6 万+</dt>
          <dd>VS Code 插件下载</dd>
        </div>
      </dl>
    </section>

    <section class="case-section">
      <div class="section-heading">
        <p class="section-kicker">Featured Projects</p>
        <h2>案例与项目证据</h2>
        <p>
          下面先放真实案例的结构占位，后续替换成具体项目、指标、架构图和链接。
        </p>
      </div>
      <div class="case-grid">
        {
          caseStudies.map((item) => (
            <article class="case-card">
              <p class="case-label">{item.label}</p>
              <h3>{item.title}</h3>
              <dl>
                <div>
                  <dt>目标问题</dt>
                  <dd>{item.problem}</dd>
                </div>
                <div>
                  <dt>Agent 能力</dt>
                  <dd>{item.agentCapability}</dd>
                </div>
                <div>
                  <dt>工程证据</dt>
                  <dd>{item.engineeringEvidence}</dd>
                </div>
              </dl>
              <p class="case-status">{item.status}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="focus-section">
      <div class="section-heading">
        <p class="section-kicker">Capability</p>
        <h2>我能为 AI Agent 团队解决什么问题</h2>
      </div>
      <div class="strength-grid">
        {
          capabilities.map((item) => (
            <section class="strength-item">
              <h3>{item.label}</h3>
              <p>{item.text}</p>
            </section>
          ))
        }
      </div>
    </section>

    {
      agentSeries && (
        <section class="featured-series">
          <div class="section-heading">
            <p class="section-kicker">Writing</p>
            <h2>核心内容：AI Agent 工程化 20 讲</h2>
            <p>
              这是当前最能代表我求职方向的内容：从系统设计、工具调用、上下文工程到评估、部署和平台化，按工程问题组织。
            </p>
          </div>
          <a class="featured-card" href={`/series/${agentSeries.slug}/`}>
            <p class="series-meta">
              {agentSeries.theme} · {agentSeries.postCount} 篇文章 ·{" "}
              {agentSeries.status}
            </p>
            <h3>{agentSeries.title}</h3>
            <p>{agentSeries.description}</p>
            <span>进入系列</span>
          </a>
        </section>
      )
    }

    {
      otherSeries.length > 0 && (
        <section class="series-section">
          <div class="section-heading">
            <p class="section-kicker">Library</p>
            <h2>专题系列</h2>
            <p>适合连续阅读的专题内容，按主题组织。</p>
          </div>
          <ul class="series-list">
            {otherSeries.map((series) => (
              <li>
                <a class="series-link" href={`/series/${series.slug}/`}>
                  <p class="series-meta">
                    {series.theme} · {series.postCount} 篇文章 · {series.status}
                  </p>
                  <h3>{series.title}</h3>
                  <p class="series-description">{series.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="recent-posts">
      <div class="section-heading">
        <p class="section-kicker">Notes</p>
        <h2>最近更新</h2>
        <p>按时间倒序记录 AI Agent、软件工程与产品思考。</p>
      </div>
      <ul>
        {posts.map((post) => <PostListItem post={post} titleAs="h3" />)}
      </ul>
      <p class="read-more"><a href="/blog">查看全部文章</a></p>
    </section>
  </main>
</BasePage>

<style>
  main {
    width: min(calc(100% - 2rem), 1080px);
  }
  .hero {
    display: grid;
    gap: 1.25rem;
    padding: 2.5rem 0 1rem;
  }

  .eyebrow,
  .section-kicker {
    margin: 0;
    color: var(--accent-dark);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    /* text-transform: uppercase; */
  }

  .hero h1 {
    /* max-width: 13em; */
    margin: 0;
    font-size: 40px;
    line-height: 0.98;
    color: rgb(var(--black));
  }

  .hero-summary {
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 1.16rem;
    line-height: 1.85;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 2.55rem;
    padding: 0.35rem 0.9rem;
    border: 1px solid rgba(var(--gray), 0.22);
    border-radius: 8px;
    color: rgb(var(--gray-dark));
    text-decoration: none;
  }

  .hero-actions a:hover {
    border-color: rgba(138, 79, 50, 0.38);
    color: var(--accent-dark);
  }

  .hero-actions .primary-action {
    border-color: var(--accent-dark);
    background: rgb(var(--black));
    color: var(--page-bg);
  }

  .hero-actions .primary-action:hover {
    background: var(--accent-dark);
    color: var(--page-bg);
  }

  .signal-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    width: min(100%, 760px);
    margin: 1rem 0 0;
    border-top: 1px solid rgba(var(--gray), 0.18);
    border-bottom: 1px solid rgba(var(--gray), 0.18);
  }

  .signal-strip div {
    padding: 1rem 1.2rem;
    border-right: 1px solid rgba(var(--gray), 0.18);
  }

  .signal-strip div:first-child {
    padding-left: 0;
  }

  .signal-strip div:last-child {
    border-right: none;
  }

  .signal-strip dt {
    margin: 0 0 0.2rem;
    color: rgb(var(--black));
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.1;
  }

  .signal-strip dd {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .case-section,
  .focus-section,
  .featured-series,
  .series-section,
  .recent-posts {
    margin-top: 4.5rem;
  }

  .section-heading {
    margin-bottom: 1.1rem;
  }

  .section-heading h2 {
    margin: 0 0 0.35rem;
  }

  .section-heading p {
    margin: 0;
    color: rgb(var(--gray));
    font-size: 0.98rem;
  }

  .section-heading .section-kicker {
    margin-bottom: 0.55rem;
    color: var(--accent-dark);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .case-card {
    display: flex;
    min-height: 24rem;
    flex-direction: column;
    padding: 1.25rem;
    border: 1px solid rgba(138, 79, 50, 0.26);
    border-radius: 8px;
    background: rgba(255, 250, 241, 0.58);
  }

  .case-label {
    margin: 0 0 0.6rem;
    color: var(--accent-dark);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .case-card h3 {
    margin: 0 0 1rem;
    font-size: 1.16rem;
    line-height: 1.35;
  }

  .case-card dl {
    display: grid;
    gap: 0.9rem;
    margin: 0;
  }

  .case-card dt {
    margin: 0 0 0.2rem;
    color: rgb(var(--black));
    font-size: 0.86rem;
    font-weight: 700;
  }

  .case-card dd {
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 0.92rem;
    line-height: 1.72;
  }

  .case-status {
    margin: auto 0 0;
    padding-top: 1rem;
    color: rgb(var(--gray));
    font-size: 0.9rem;
    font-weight: 700;
  }

  .strength-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid rgba(var(--gray), 0.18);
    border-radius: 8px;
    background: rgba(var(--gray), 0.18);
  }

  .strength-item {
    min-height: 15rem;
    padding: 1.35rem;
    background: rgba(255, 250, 241, 0.64);
  }

  .strength-item h3 {
    margin: 0 0 0.7rem;
    font-size: 1.12rem;
  }

  .strength-item p {
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 0.98rem;
    line-height: 1.8;
  }

  .featured-card {
    display: block;
    padding: 1.6rem;
    border: 1px solid rgba(138, 79, 50, 0.26);
    border-radius: 8px;
    background: linear-gradient(135deg, #fffaf1 0%, #f0e2d1 100%);
    color: rgb(var(--gray-dark));
    text-decoration: none;
  }

  .featured-card h3 {
    margin: 0 0 0.6rem;
    font-size: 1.65rem;
  }

  .featured-card p {
    max-width: 48rem;
    margin: 0 0 0.8rem;
    line-height: 1.85;
  }

  .featured-card span {
    color: var(--accent-dark);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .series-list,
  .recent-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(var(--gray), 0.18);
  }

  .series-list li,
  .recent-posts li {
    border-bottom: 1px solid rgba(var(--gray), 0.18);
  }

  .series-list li:last-child {
    border-bottom: none;
  }

  .recent-posts li:last-child {
    border-bottom: none;
  }

  .series-link,
  .post-link {
    display: block;
    padding: 1.35rem 0;
    text-decoration: none;
  }
  .series-link h3,
  .post-link h3 {
    margin: 0 0 0.35rem;
    line-height: 1.35;
  }

  .series-link:hover h3,
  .post-link:hover h3 {
    color: var(--accent);
  }

  .series-meta,
  .series-description {
    margin: 0;
    color: rgb(var(--gray-dark));
    line-height: 1.85;
  }

  .series-meta {
    color: rgb(var(--gray));
    font-size: 0.9rem;
  }

  .read-more {
    margin-top: 1.1rem;
    font-size: 0.95rem;
  }

  @media (max-width: 760px) {
    main {
      width: min(calc(100% - 1.25rem), 860px);
      padding-top: 2rem;
    }

    .hero {
      padding-top: 1.25rem;
    }

    .hero h1 {
      font-size: clamp(2.35rem, 14vw, 3.6rem);
    }

    .hero-summary {
      font-size: 1.02rem;
    }

    .signal-strip,
    .strength-grid,
    .case-grid {
      grid-template-columns: 1fr;
    }

    .signal-strip div {
      padding: 0.9rem 0;
      border-right: none;
      border-bottom: 1px solid rgba(var(--gray), 0.18);
    }

    .signal-strip div:last-child {
      border-bottom: none;
    }

    .strength-item {
      min-height: auto;
    }
  }
</style>
