---
import { getCollection } from "astro:content";
import BasePage from "../../layouts/BasePage.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import { getSeriesSummaries, sortPosts } from "../../utils/blog";

const posts = sortPosts({
  posts: await getCollection("blog"),
});
const seriesList = getSeriesSummaries({ posts });
---

<BasePage title={`系列 | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <main>
    <ul class="series-list">
      {
        seriesList.map((series) => (
          <li>
            <a class="series-link" href={`/series/${series.slug}/`}>
              <p class="series-meta">
                {series.theme} · {series.postCount} 篇文章 · {series.status}
              </p>
              <h2>{series.title}</h2>
              <p>{series.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BasePage>
<style>
  main {
    width: min(calc(100% - 2rem), 860px);
  }

  .series-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgb(var(--gray-light));
  }

  .series-list li {
    border-bottom: 1px solid rgb(var(--gray-light));
  }

  .series-list li:last-child {
    border-bottom: none;
  }

  .series-link {
    display: block;
    padding: 1.35rem 0;
    text-decoration: none;
  }

  .series-link h2 {
    margin: 0 0 0.4rem;
    font-size: 1.4rem;
  }

  .series-link p {
    margin: 0;
    color: rgb(var(--gray));
    line-height: 1.8;
  }

  .series-link:hover h2 {
    color: var(--accent);
  }

  .series-meta {
    margin-bottom: 0.45rem;
    font-size: 0.92rem;
    color: rgb(var(--gray));
  }

  @media (max-width: 760px) {
    main {
      width: min(calc(100% - 1.25rem), 860px);
    }
    .page-heading {
      margin-bottom: 2.25rem;
    }

    .series-link h2 {
      font-size: 1.2rem;
    }
  }
</style>
