---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import SeriesDocsShell from "../../components/SeriesDocsShell.astro";
import { SITE_TITLE } from "../../consts";
import { SERIES_LIST, type SeriesConfig } from "../../data/series";
import BasePage from "../../layouts/BasePage.astro";
import { getSeriesPosts, sortPosts } from "../../utils/blog";

export async function getStaticPaths() {
  const posts = sortPosts({
    posts: await getCollection("blog"),
  });

  return SERIES_LIST.map((series) => ({
    params: { slug: series.slug },
    props: {
      series,
      posts: getSeriesPosts({
        posts,
        slug: series.slug,
      }),
    },
  }));
}

type Props = {
  series: SeriesConfig;
  posts: CollectionEntry<"blog">[];
};

const { series, posts } = Astro.props;
const firstPost = posts[0];
const latestPost = posts[posts.length - 1];
---

<BasePage
  title={`${series.title} | ${SITE_TITLE}`}
  description={series.description}
>
  <SeriesDocsShell title={series.title} posts={posts}>
    <article class="series-content">
      <header class="series-header">
        <p class="series-kicker">系列首页</p>
        <a class="back-link" href="/series">返回系列列表</a>
        <h1>{series.title}</h1>
        <p class="series-summary">
          {series.theme} · {posts.length} 篇文章 · {series.status}
        </p>
        <p class="series-description">{series.description}</p>
      </header>

      <section class="content-section">
        <h2>如何阅读这个系列</h2>
        <p>
          这个页面相当于系列导读，不指向某一篇具体文章，而是先说明这个系列想解决什么问题、覆盖哪些范围，以及应该如何开始阅读。
        </p>
        <p>
          左侧是完整目录。建议按顺序阅读；如果你已经有明确问题，也可以直接跳到对应章节。
        </p>
      </section>

      <section class="content-section">
        <h2>当前状态</h2>
        {
          posts.length > 0 ? (
            <ul class="series-facts">
              <li>主题：{series.theme}</li>
              <li>状态：{series.status}</li>
              <li>文章数量：{posts.length} 篇</li>
              <li>起始文章：{firstPost?.data.title}</li>
              <li>最新文章：{latestPost?.data.title}</li>
            </ul>
          ) : (
            <p class="empty-note">
              这个系列已经建档，但当前还没有正式发布文章。
            </p>
          )
        }
      </section>
    </article>
  </SeriesDocsShell>
</BasePage>
<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.92rem;
    text-decoration: none;
  }

  .series-content {
    min-width: 0;
    padding: 0 0 4rem;
  }

  .series-header {
    margin-bottom: 2.5rem;
  }

  .series-kicker {
    margin: 0 0 0.6rem;
    color: rgb(var(--gray));
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .series-header h1 {
    margin: 0 0 0.65rem;
    max-width: 15ch;
  }

  .series-summary {
    margin: 0 0 1rem;
    color: rgb(var(--gray));
    font-size: 0.95rem;
  }

  .series-description {
    max-width: 48rem;
    margin: 0;
    color: rgb(var(--gray-dark));
    font-size: 1.08rem;
    line-height: 1.9;
  }

  .content-section + .content-section {
    margin-top: 2.5rem;
  }

  .content-section h2 {
    margin-top: 0;
    margin-bottom: 0.9rem;
    font-size: 1.3rem;
  }

  .content-section p,
  .content-section li {
    color: rgb(var(--gray-dark));
    line-height: 1.9;
  }

  .content-section ul {
    margin: 0;
  }

  .series-facts {
    padding-left: 1.1rem;
  }

  .empty-note {
    color: rgb(var(--gray));
  }
  
  @media (max-width: 760px) {
    .series-description {
      font-size: 1rem;
    }
  }
</style>
