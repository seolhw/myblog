---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostListItem from '../../components/PostListItem.astro';
import { SITE_TITLE } from '../../consts';
import { SERIES_LIST, type SeriesConfig } from '../../data/series';
import { getSeriesPosts, sortPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = sortPosts({
		posts: await getCollection('blog'),
	});

	return SERIES_LIST.map((series) => ({
		params: { slug: series.slug },
		props: {
			series,
			posts: getSeriesPosts({
				posts,
				slug: series.slug,
			}),
		},
	}));
}

type Props = {
	series: SeriesConfig;
	posts: CollectionEntry<'blog'>[];
};

const { series, posts } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${series.title} | ${SITE_TITLE}`} description={series.description} />
		<style>
			main {
				width: 720px;
			}

			.back-link {
				display: inline-block;
				margin-bottom: 1.5rem;
				font-size: 0.95rem;
			}

			.page-heading {
				margin-bottom: 3rem;
			}

			.page-heading p {
				max-width: 44rem;
				color: rgb(var(--gray));
			}

			.series-summary {
				margin: 0 0 1rem;
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}

			.series-description {
				margin: 0;
				font-size: 1.08rem;
				line-height: 1.9;
				color: rgb(var(--gray-dark));
			}

			.reading-note {
				margin: 1.25rem 0 0;
				padding-left: 1rem;
				border-left: 2px solid rgb(var(--gray-light));
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}

			.empty-state {
				padding: 1rem 0 0;
				color: rgb(var(--gray));
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
				border-top: 1px solid rgb(var(--gray-light));
			}

			.post-list li {
				border-bottom: 1px solid rgb(var(--gray-light));
			}

			@media (max-width: 720px) {
				main {
					width: 100%;
				}

				.page-heading {
					margin-bottom: 2.25rem;
				}

				.series-description {
					font-size: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-heading">
				<a class="back-link" href="/series">返回系列列表</a>
				<h2>{series.title}</h2>
				<p class="series-summary">
					{series.theme} · {posts.length} 篇文章 · {series.status}
				</p>
				<p class="series-description">{series.description}</p>
				<p class="reading-note">建议按顺序阅读。这个页面更像目录，先帮助你快速判断每一讲讲什么，再进入正文。</p>
			</header>
			{
				posts.length === 0 ? (
					<div class="empty-state">
						<p>这个系列已经建档，当前还没有正式发布文章。</p>
						<p>
							后续给文章 frontmatter 补上 <code>series: "{series.slug}"</code> 和 <code>seriesOrder</code>
							后，这里会自动聚合。
						</p>
					</div>
				) : (
					<ul class="post-list">
						{
							posts.map((post) => <PostListItem post={post} titleAs="h4" />)
						}
					</ul>
				)
			}
		</main>
		<Footer />
	</body>
</html>
