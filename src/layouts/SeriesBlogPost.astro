---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import ArticleToc from "../components/ArticleToc.astro";
import PostMeta from "../components/PostMeta.astro";
import SeriesDocsShell from "../components/SeriesDocsShell.astro";
import BasePage from "./BasePage.astro";
import { getSeriesBySlug } from "../data/series";

type HeadingItem = {
  depth: number;
  slug: string;
  text: string;
};

type Props = CollectionEntry<"blog">["data"] & {
  currentPostId: string;
  headings?: HeadingItem[];
  seriesPosts: CollectionEntry<"blog">[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  series,
  seriesOrder,
  topics = [],
  currentPostId,
  headings = [],
  seriesPosts,
} = Astro.props;
const currentSeries = getSeriesBySlug({ slug: series });
---

<BasePage title={title} description={description}>
  <SeriesDocsShell
    title={currentSeries?.title || ""}
    posts={seriesPosts}
    currentPostId={currentPostId}
  >
    <div class="prose">
      <div class="title">
        <h2>{title}</h2>
        <div class="date">
          <div>更新于：<FormattedDate date={pubDate} /></div>
          <PostMeta series={series} seriesOrder={seriesOrder} topics={topics} />
        </div>
        <div class="series-summary">
          <p>
            这篇文章收录在系列&nbsp;
            <a href={`/series/${currentSeries?.slug || ""}/`}>
              {currentSeries?.title}
            </a>
            &nbsp; 中。
          </p>
          <p>{currentSeries?.description}</p>
        </div>
        <hr />
        {description && <p class="description">摘要：{description}</p>}
      </div>
      <slot />
    </div>
    <Fragment slot="right">
      <ArticleToc headings={headings} />
    </Fragment>
  </SeriesDocsShell>
</BasePage>

<style>
  h2 {
    margin-bottom: 1rem;
  }
  .prose {
    width: 100%;
    padding: 0 0 4.5rem;
    color: rgb(var(--gray-dark));
  }
  .title {
    margin-bottom: 2.5rem;
    text-align: left;
    line-height: 1.3;
  }

  .date {
    margin-bottom: 0.65rem;
    color: rgb(var(--gray));
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .last-updated-on {
    display: inline;
    margin-left: 0.5rem;
  }
  .description {
    max-width: 42rem;
    margin-bottom: 1rem;
    color: rgb(var(--gray));
    font-size: 1.06rem;
    line-height: 1.9;
  }
  .series-summary {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    color: rgb(var(--gray));
  }
  .series-summary p {
    margin: 0 0 0.45rem;
  }
  .series-summary p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 760px) {
    .prose {
      padding-bottom: 3rem;
    }
    .last-updated-on {
      display: block;
      margin: 0.2rem 0 0;
    }
  }
</style>
