---
import { GITHUB_URL, SITE_TITLE } from "../consts";
import { SERIES_LIST } from "../data/series";
import HeaderLink from "./HeaderLink.astro";
import profile from "../assets/profile.jpg";
import { Image } from "astro:assets";
---

<header>
  <nav>
    <h2>
      <Image src={profile} alt="profile" width="40" height="40" />
      <a href="/">{SITE_TITLE}</a>
    </h2>
    <div class="internal-links">
      <HeaderLink href="/">首页</HeaderLink>
      <HeaderLink href="/blog">文章</HeaderLink>
      <HeaderLink href="/series">系列</HeaderLink>
      {
        SERIES_LIST.slice(0, 3).map((series) => (
          <HeaderLink href={`/series/${series.slug}`}>{series.title}</HeaderLink>
        ))
      }
      <HeaderLink href="/timeline">时间线</HeaderLink>
      <HeaderLink href="/about">关于</HeaderLink>
    </div>
    <div class="external-links">
      <a href={GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
    </div>
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1rem;
    background: rgba(251, 250, 247, 92%);
    border-bottom: 1px solid rgba(var(--gray-light), 80%);
    backdrop-filter: blur(16px);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  h2 {
    margin: 0;
    font-size: 1rem;
    white-space: nowrap;
    display: flex;
    align-items: center;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(100%, 960px);
    min-height: 64px;
    margin: 0 auto;
  }
  nav a {
    padding: 0.5rem 0.35rem;
    color: rgb(var(--gray-dark));
    border-bottom: 2px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
    border-bottom-color: var(--accent);
    color: rgb(var(--black));
  }
  .internal-links {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .external-links {
    display: flex;
    align-items: center;
  }
  @media (max-width: 760px) {
    nav {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.2rem;
      padding: 0.7rem 0;
    }
    .internal-links {
      width: 100%;
      gap: 0.5rem;
      overflow-x: auto;
    }
    .external-links {
      display: none;
    }
  }
</style>
