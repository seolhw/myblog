---
import type { CollectionEntry } from "astro:content";
import SeriesPostNav from "./SeriesPostNav.astro";

interface Props {
  title: string;
  posts: CollectionEntry<"blog">[];
  currentPostId?: string;
}

const { title, posts, currentPostId } = Astro.props;
const hasRightSlot = Astro.slots.has("right");
---

<div class="series-page-main">
  <div class:list={["series-shell", { "with-right-sidebar": hasRightSlot }]}>
    <aside class="series-sidebar">
      <SeriesPostNav
        title={title}
        posts={posts}
        currentPostId={currentPostId}
      />
    </aside>
    <section class="series-content">
      <slot />
    </section>
    {
      hasRightSlot && (
        <aside class="toc-sidebar">
          <slot name="right" />
        </aside>
      )
    }
  </div>
</div>

<style>
  .series-page-main {
    width: min(calc(100% - 2rem), 1380px);
    margin: auto;
    height: calc(100vh - 64px - 1rem);
    padding-top: 1rem;
    overflow: hidden;
  }

  .series-shell {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 1.75rem;
    align-items: start;
    height: 100%;
  }

  .series-shell.with-right-sidebar {
    grid-template-columns: 300px minmax(0, 1fr) 180px;
  }

  .series-sidebar,
  .series-content,
  .toc-sidebar {
    min-width: 0;
  }

  .series-content {
    position: relative;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .series-sidebar {
    padding-right: 1.25rem;
    border-right: 1px solid rgba(var(--gray-light), 0.9);
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .toc-sidebar {
    padding-left: 1rem;
    border-left: 1px solid rgba(var(--gray-light), 0.9);
  }

  .series-sidebar :global(.series-nav) {
    position: static;
    top: auto;
  }

  @media (max-width: 1180px) {
    .series-page-main {
      width: min(calc(100% - 1.5rem), 980px);
    }

    .series-shell.with-right-sidebar {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 1.6rem;
    }
  }

  @media (max-width: 980px) {
    .series-page-main {
      width: min(calc(100% - 1.25rem), 1380px);
      height: auto;
      padding-top: 1rem;
      overflow: visible;
    }

    .series-shell,
    .series-shell.with-right-sidebar {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      height: auto;
    }

    .series-sidebar {
      order: -1;
      padding-right: 0;
      border-right: none;
      overflow: visible;
    }

    .toc-sidebar {
      padding-left: 0;
      border-left: none;
    }

    .series-content {
      overflow: visible;
    }
  }
</style>
