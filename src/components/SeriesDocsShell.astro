---
import type { CollectionEntry } from "astro:content";
import SeriesPostNav from "./SeriesPostNav.astro";

interface Props {
  title: string;
  posts: CollectionEntry<"blog">[];
  currentPostId?: string;
}

const { title, posts, currentPostId } = Astro.props;
const hasRightSlot = Astro.slots.has("right");
---

<div class="series-page-main">
  <div class:list={["series-shell", { "with-right-sidebar": hasRightSlot }]}>
    <div class="scroll-frame series-sidebar-frame" data-scroll-frame>
      <aside class="series-sidebar" data-scroll-pane>
        <SeriesPostNav
          title={title}
          posts={posts}
          currentPostId={currentPostId}
        />
      </aside>
      <span class="floating-scrollbar" aria-hidden="true"></span>
    </div>
    <div class="scroll-frame series-content-frame" data-scroll-frame>
      <section class="series-content" data-scroll-pane>
        <slot />
      </section>
      <span class="floating-scrollbar" aria-hidden="true"></span>
    </div>
    {
      hasRightSlot && (
        <aside class="toc-sidebar">
          <slot name="right" />
        </aside>
      )
    }
  </div>
</div>

<style>
  .series-page-main {
    width: min(calc(100% - 2rem), 1380px);
    margin: auto;
    flex: 1;
    min-height: 0;
    height: 100%;
    padding-top: 1rem;
    overflow: hidden;
  }

  .series-shell {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: 1.75rem;
    align-items: stretch;
    height: 100%;
    min-height: 0;
  }

  .series-shell.with-right-sidebar {
    grid-template-columns: 300px minmax(0, 1fr) 180px;
  }

  .scroll-frame,
  .series-content,
  .toc-sidebar {
    min-width: 0;
    min-height: 0;
  }

  .scroll-frame {
    position: relative;
    height: 100%;
  }

  .series-content {
    height: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .series-sidebar-frame {
    height: 100%;
    padding-right: 1.25rem;
    border-right: 1px solid rgba(var(--gray-light), 0.9);
  }

  .series-sidebar {
    height: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .series-page-main,
  .series-sidebar,
  .series-content {
    scrollbar-width: none;
    scrollbar-color: transparent transparent;
  }

  .series-page-main::-webkit-scrollbar,
  .series-sidebar::-webkit-scrollbar,
  .series-content::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  .floating-scrollbar {
    position: absolute;
    top: var(--scrollbar-top, 8px);
    right: 2px;
    z-index: 2;
    width: 4px;
    height: var(--scrollbar-height, 40px);
    border-radius: 999px;
    background: rgba(var(--gray), 0.2);
    opacity: 0;
    pointer-events: none;
    transform: translateZ(0);
    transition:
      opacity 140ms ease,
      background-color 140ms ease;
  }

  .scroll-frame.is-scrollable:hover .floating-scrollbar,
  .scroll-frame.is-scrollable:focus-within .floating-scrollbar,
  .scroll-frame.is-scrollable.is-scrolling .floating-scrollbar {
    opacity: 1;
  }

  .scroll-frame.is-scrollable:hover .floating-scrollbar {
    background: rgba(var(--gray-dark), 0.28);
  }

  .toc-sidebar {
    padding-left: 1rem;
    border-left: 1px solid rgba(var(--gray-light), 0.9);
  }

  .series-sidebar :global(.series-nav) {
    position: static;
    top: auto;
  }

  @media (max-width: 1180px) {
    .series-page-main {
      width: min(calc(100% - 1.5rem), 980px);
    }

    .series-shell.with-right-sidebar {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 1.6rem;
    }
  }

  @media (max-width: 980px) {
    .series-page-main {
      width: min(calc(100% - 1.25rem), 1380px);
      padding-top: 1rem;
      overflow-y: auto;
    }

    .series-shell,
    .series-shell.with-right-sidebar {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      min-height: min-content;
    }

    .series-sidebar-frame {
      order: -1;
      padding-right: 0;
      border-right: none;
      height: auto;
    }

    .toc-sidebar {
      padding-left: 0;
      border-left: none;
    }

    .series-content {
      overflow: visible;
    }

    .scroll-frame {
      height: auto;
    }

    .floating-scrollbar {
      display: none;
    }
  }
</style>

<script>
  const setupFloatingScrollbars = () => {
    const frames = document.querySelectorAll("[data-scroll-frame]");

    frames.forEach((frame) => {
      const pane = frame.querySelector("[data-scroll-pane]");
      if (!(pane instanceof HTMLElement) || !(frame instanceof HTMLElement)) {
        return;
      }

      let scrollTimeout;
      let frameId;

      const update = () => {
        const scrollable = pane.scrollHeight > pane.clientHeight + 1;
        frame.classList.toggle("is-scrollable", scrollable);

        if (!scrollable) {
          return;
        }

        const inset = 8;
        const trackHeight = Math.max(0, frame.clientHeight - inset * 2);
        const maxScroll = Math.max(1, pane.scrollHeight - pane.clientHeight);
        const maxThumbTop = Math.max(0, trackHeight - 44);
        const progress = pane.scrollTop / maxScroll;
        const thumbTop = inset + progress * maxThumbTop;

        frame.style.setProperty("--scrollbar-height", "44px");
        frame.style.setProperty("--scrollbar-top", `${thumbTop}px`);
      };

      const scheduleUpdate = () => {
        cancelAnimationFrame(frameId);
        frameId = requestAnimationFrame(update);
      };

      const markScrolling = () => {
        frame.classList.add("is-scrolling");
        window.clearTimeout(scrollTimeout);
        scrollTimeout = window.setTimeout(() => {
          frame.classList.remove("is-scrolling");
        }, 600);
      };

      pane.addEventListener(
        "scroll",
        () => {
          scheduleUpdate();
          markScrolling();
        },
        { passive: true },
      );

      const observer = new ResizeObserver(scheduleUpdate);
      observer.observe(frame);
      observer.observe(pane);

      scheduleUpdate();
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupFloatingScrollbars, {
      once: true,
    });
  } else {
    setupFloatingScrollbars();
  }
</script>
