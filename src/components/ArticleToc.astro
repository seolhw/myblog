---
interface HeadingItem {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: HeadingItem[];
}

const { headings } = Astro.props;
const tocHeadings = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 3,
);
---

{
  tocHeadings.length > 0 && (
    <nav class="article-toc" aria-label="本页目录">
      <p class="eyebrow">本页目录</p>
      <ul>
        {tocHeadings.map((heading) => (
          <li class:list={[`depth-${heading.depth}`]}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  type ScrollBehaviorMode = ScrollBehavior;
  type TocTarget = {
    hash: string;
    target: HTMLElement;
  };

  const tocControllers = new WeakMap<HTMLElement, AbortController>();

  const getTocLinks = (toc: HTMLElement): HTMLAnchorElement[] =>
    Array.from(toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'));

  const findTarget = (hash: string | null): HTMLElement | null => {
    if (!hash || hash === "#") {
      return null;
    }

    const rawId = hash.slice(1);

    try {
      return document.getElementById(decodeURIComponent(rawId));
    } catch {
      return document.getElementById(rawId);
    }
  };

  const isScrollable = (element: HTMLElement | null): element is HTMLElement =>
    Boolean(element && element.scrollHeight > element.clientHeight + 1);

  const getScrollRoot = (): HTMLElement => {
    const content = document.querySelector<HTMLElement>(".series-content");
    const page = document.querySelector<HTMLElement>(".series-page-main");

    if (isScrollable(content)) {
      return content;
    }

    if (isScrollable(page)) {
      return page;
    }

    return (
      (document.scrollingElement instanceof HTMLElement
        ? document.scrollingElement
        : null) ?? document.documentElement
    );
  };

  const scrollTargetIntoRoot = (
    target: HTMLElement,
    behavior: ScrollBehaviorMode = "smooth",
  ) => {
    const root = getScrollRoot();
    const rootRect = root.getBoundingClientRect();
    const targetRect = target.getBoundingClientRect();
    const top = root.scrollTop + targetRect.top - rootRect.top - 16;

    root.scrollTo({
      top: Math.max(0, top),
      behavior,
    });
  };

  const setActiveLink = (toc: HTMLElement, hash: string) => {
    getTocLinks(toc).forEach((link) => {
      if (link.getAttribute("href") === hash) {
        link.setAttribute("aria-current", "location");
        return;
      }

      link.removeAttribute("aria-current");
    });
  };

  const getTocTargets = (toc: HTMLElement): TocTarget[] =>
    getTocLinks(toc)
      .map((link) => {
        const hash = link.getAttribute("href");
        const target = findTarget(hash);

        if (!hash || !target) {
          return null;
        }

        return { hash, target };
      })
      .filter((item): item is TocTarget => item !== null);

  const syncActiveHeading = (toc: HTMLElement) => {
    const targets = getTocTargets(toc);

    if (targets.length === 0) {
      return;
    }

    const root = getScrollRoot();
    const rootTop = root.getBoundingClientRect().top;
    let activeHash = targets[0].hash;

    for (const item of targets) {
      const top = item.target.getBoundingClientRect().top - rootTop;

      if (top <= 28) {
        activeHash = item.hash;
      }
    }

    setActiveLink(toc, activeHash);
  };

  const enhanceToc = (toc: HTMLElement) => {
    tocControllers.get(toc)?.abort();

    const controller = new AbortController();
    const { signal } = controller;
    tocControllers.set(toc, controller);

    getTocLinks(toc).forEach((link) => {
      link.addEventListener(
        "click",
        (event) => {
          const hash = link.getAttribute("href");
          const target = findTarget(hash);

          if (!hash || !target) {
            return;
          }

          event.preventDefault();
          scrollTargetIntoRoot(target);
          history.pushState(null, "", hash);
          setActiveLink(toc, hash);
        },
        { signal },
      );
    });

    let frame = 0;
    const root = getScrollRoot();
    const onScroll = () => {
      if (frame) {
        return;
      }

      frame = requestAnimationFrame(() => {
        frame = 0;
        syncActiveHeading(toc);
      });
    };

    root.addEventListener("scroll", onScroll, { passive: true, signal });
    syncActiveHeading(toc);
  };

  const initArticleToc = () => {
    document.querySelectorAll<HTMLElement>(".article-toc").forEach((toc) => {
      enhanceToc(toc);
    });

    const target = findTarget(window.location.hash);
    if (target) {
      requestAnimationFrame(() => scrollTargetIntoRoot(target, "auto"));
    }
  };

  document.addEventListener("astro:page-load", initArticleToc);
  initArticleToc();
</script>

<style>
  .article-toc {
    position: sticky;
    top: 5.5rem;
    padding: 0.15rem 0;
  }

  .eyebrow {
    margin: 0 0 0.7rem;
    color: rgb(var(--gray));
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li + li {
    margin-top: 0.35rem;
  }

  li.depth-3 {
    padding-left: 0.85rem;
  }

  a {
    color: rgb(var(--gray));
    text-decoration: none;
    font-size: 0.88rem;
    line-height: 1.55;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--accent-dark);
  }

  a[aria-current="location"] {
    color: var(--accent-dark);
    font-weight: 700;
  }

  @media (max-width: 1180px) {
    .article-toc {
      display: none;
    }
  }
</style>
