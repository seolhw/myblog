---
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  posts: CollectionEntry<"blog">[];
  currentPostId?: string;
}

const { title, posts, currentPostId } = Astro.props;
const groupedPosts = posts.reduce<
  { name: string; posts: CollectionEntry<"blog">[] }[]
>((groups, post) => {
  const groupName = post.data.seriesGroup?.trim() || "未分组";
  const currentGroup = groups.at(-1);

  if (currentGroup && currentGroup.name === groupName) {
    currentGroup.posts.push(post);
    return groups;
  }

  groups.push({
    name: groupName,
    posts: [post],
  });

  return groups;
}, []);
---

<div class="series-nav">
  <p class="eyebrow">讲义</p>
  <h2>{title}</h2>
  {
    groupedPosts.map((group) => (
      <section class="group">
        <p class="group-title">{group.name}</p>
        <ol class="posts">
          {group.posts.map((post, index) => (
            <li>
              <a
                href={`/blog/${post.id}/`}
                class:list={{ active: post.id === currentPostId }}
              >
                <span class="text">{post.data.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </section>
    ))
  }
</div>

<style>
  .series-nav {
    position: sticky;
    top: 5.5rem;
    padding: 0.15rem 0;
  }

  .posts {
    margin-left: 1rem;
  }

  .eyebrow {
    margin: 0 0 0.5rem;
    color: rgb(var(--gray));
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .group + .group {
    margin-top: 1.1rem;
  }

  .group-title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.45;
    font-weight: 600;
  }

  ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li + li {
    margin-top: 0.35rem;
  }

  a {
    display: flex;
    gap: 0.7rem;
    padding: 0.38rem 0;
    color: rgb(var(--gray-dark));
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: rgb(var(--black));
  }

  a.active {
    color: var(--accent-dark);
  }

  .order {
    flex-shrink: 0;
    width: 1.8rem;
    color: rgb(var(--gray));
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
  }

  a.active .order,
  a.active .text {
    color: var(--accent-dark);
    font-weight: 600;
  }

  .text {
    font-size: 0.92rem;
    line-height: 1.5;
  }

  @media (max-width: 980px) {
    .series-nav {
      position: static;
    }
  }
</style>
